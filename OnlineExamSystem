#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

#define MAX_STUDENTS 50
#define MAX_Q 20

typedef struct {
    char question[150];
    char options[4][60];
    int answer;
} Question;

typedef struct {
    char rollNo[12];
    char name[30];
    int score;
    int attempted;
    char grade[3];
    char result[8];
} Student;

Question questions[MAX_Q] = {
    {"What is the size of int in Java?", {"2 bytes","4 bytes","8 bytes","1 byte"}, 2},
    {"Which is not an OOP principle?", {"Inheritance","Polymorphism","Compilation","Encapsulation"}, 3},
    {"What does JVM stand for?", {"Java Virtual Machine","Java Variable Memory","Java Verified Module","None"}, 1},
    {"Which is a valid Java comment?", {"/* comment */","# comment","// comment","Both A and C"}, 4},
    {"What is the default value of int in Java?", {"null","0","undefined","-1"}, 2},
    {"Which keyword is used for inheritance?", {"implements","inherit","extends","derives"}, 3},
    {"What is the output of 10 % 3?", {"3","1","0","2"}, 2},
    {"Which is not a primitive type?", {"int","float","String","char"}, 3},
    {"Scanner class belongs to which package?", {"java.util","java.io","java.lang","java.net"}, 1},
    {"What is polymorphism?", {"One form","Many forms","No form","Two forms"}, 2}
};
int totalQ = 10;

Student results[MAX_STUDENTS];
int resultCount = 0;

void startExam() {
    char name[30], roll[12];
    printf("Enter Your Name: ");
    scanf(" %[^\n]", name);
    printf("Enter Roll Number: ");
    scanf("%s", roll);
    printf("\n========================================\n");
    printf("          ONLINE EXAMINATION\n");
    printf("========================================\n");
    printf("Total Questions: %d | Time: 20 minutes\n", totalQ);
    printf("Each question carries 1 mark. No negative marking.\n");
    printf("----------------------------------------\n");
    printf("Press Enter to start exam...");
    getchar(); getchar();

    int score = 0, attempted = 0;
    int userAnswers[MAX_Q] = {0};

    for (int i = 0; i < totalQ; i++) {
        printf("\nQ%d: %s\n", i + 1, questions[i].question);
        for (int j = 0; j < 4; j++) {
            printf("  %d. %s\n", j + 1, questions[i].options[j]);
        }
        int ans;
        do {
            printf("Your Answer (1-4, 0 to skip): ");
            scanf("%d", &ans);
        } while (ans < 0 || ans > 4);

        userAnswers[i] = ans;
        if (ans != 0) {
            attempted++;
            if (ans == questions[i].answer) {
                score++;
                printf("Correct!\n");
            } else {
                printf("Wrong! Correct answer: %d. %s\n",
                    questions[i].answer, questions[i].options[questions[i].answer - 1]);
            }
        } else {
            printf("Skipped.\n");
        }
    }

    float percent = (float)score / totalQ * 100;
    char *grade;
    if (percent >= 90) grade = "A+";
    else if (percent >= 80) grade = "A";
    else if (percent >= 70) grade = "B";
    else if (percent >= 60) grade = "C";
    else if (percent >= 50) grade = "D";
    else grade = "F";
    char *result = percent >= 50 ? "PASS" : "FAIL";

    strcpy(results[resultCount].name, name);
    strcpy(results[resultCount].rollNo, roll);
    results[resultCount].score = score;
    results[resultCount].attempted = attempted;
    strcpy(results[resultCount].grade, grade);
    strcpy(results[resultCount].result, result);
    resultCount++;

    printf("\n========================================\n");
    printf("              RESULT CARD\n");
    printf("========================================\n");
    printf("Name       : %s\n", name);
    printf("Roll No    : %s\n", roll);
    printf("Attempted  : %d/%d\n", attempted, totalQ);
    printf("Score      : %d/%d\n", score, totalQ);
    printf("Percentage : %.2f%%\n", percent);
    printf("Grade      : %s\n", grade);
    printf("Result     : %s\n", result);
    printf("========================================\n");
}

void viewResults() {
    if (resultCount == 0) { printf("No results yet!\n"); return; }
    printf("\n--- EXAM RESULTS ---\n");
    printf("%-12s %-20s %-8s %-6s %-6s %-8s\n",
        "Roll No", "Name", "Score", "%%", "Grade", "Result");
    printf("%s\n", "--------------------------------------------------------------");
    for (int i = 0; i < resultCount; i++) {
        float pct = (float)results[i].score / totalQ * 100;
        printf("%-12s %-20s %-8d %-6.1f %-6s %-8s\n",
            results[i].rollNo, results[i].name, results[i].score,
            pct, results[i].grade, results[i].result);
    }
}

void viewQuestions() {
    printf("\n--- QUESTION BANK ---\n");
    for (int i = 0; i < totalQ; i++) {
        printf("Q%d: %s\n", i+1, questions[i].question);
        for (int j = 0; j < 4; j++)
            printf("  %d. %s%s\n", j+1, questions[i].options[j],
                j+1 == questions[i].answer ? " [CORRECT]" : "");
    }
}

void toppersList() {
    if (resultCount == 0) { printf("No results!\n"); return; }
    printf("\n--- TOP PERFORMERS ---\n");
    for (int i = 0; i < resultCount - 1; i++) {
        for (int j = 0; j < resultCount - i - 1; j++) {
            if (results[j].score < results[j+1].score) {
                Student temp = results[j];
                results[j] = results[j+1];
                results[j+1] = temp;
            }
        }
    }
    for (int i = 0; i < resultCount && i < 5; i++) {
        printf("Rank %d: %s (%s) - Score: %d/%d - %s\n",
            i+1, results[i].name, results[i].rollNo,
            results[i].score, totalQ, results[i].grade);
    }
}

int main() {
    int choice;
    printf("==========================================\n");
    printf("         ONLINE EXAMINATION SYSTEM\n");
    printf("==========================================\n");
    do {
        printf("\n1. Start Exam\n2. View Results\n3. View Question Bank\n4. Toppers List\n5. Exit\n");
        printf("Choice: ");
        scanf("%d", &choice);
        switch (choice) {
            case 1: startExam(); break;
            case 2: viewResults(); break;
            case 3: viewQuestions(); break;
            case 4: toppersList(); break;
            case 5: printf("Exam system closed.\n"); break;
            default: printf("Invalid!\n");
        }
    } while (choice != 5);
    return 0;
}
